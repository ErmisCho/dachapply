# Local one-server mode: Django serves the built React app and API.
# Use this if you do not want to run `npm run dev` separately.

DEBUG=True
DACHAPPLY_ENV=local-one-server
DACHAPPLY_DEMO_SEED_SCHEDULER=0

# Use 8000 because the frontend is served by Django in this mode.
FRONTEND_URL=http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Neon/Postgres local option. Paste your Neon URL if you want local to use Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_SSL_REQUIRE=True

# Local email: password reset emails print in the backend terminal.
EMAIL_PROVIDER=console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=DACHApply <local@dachapply.test>
EMAIL_TIMEOUT=10
