# DACHApply production environment template
# Generate a strong key, e.g. python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me
DEBUG=False

# Comma-separated hostnames without scheme.
ALLOWED_HOSTS=your-domain.example.com

# Public frontend/base URL. Usually same origin as Django in production.
FRONTEND_URL=https://your-domain.example.com

# Origins with scheme that may POST with CSRF cookies.
# Include your production origin, and any separate frontend origin if used.
CSRF_TRUSTED_ORIGINS=https://your-domain.example.com
CORS_ALLOWED_ORIGINS=https://your-domain.example.com

# Security/proxy settings. For Azure/Render/Heroku-style TLS termination keep these true.
SECURE_SSL_REDIRECT=True
USE_X_FORWARDED_PROTO=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# Enable HSTS only after HTTPS is confirmed working.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# PostgreSQL. Prefer DATABASE_URL in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=True

# Email for password resets.
# EMAIL_PROVIDER=auto means: use Brevo if Brevo credentials are filled;
# otherwise use LOCAL_* SMTP if filled; otherwise use legacy EMAIL_* defaults.
EMAIL_PROVIDER=auto
EMAIL_TIMEOUT=10

# Brevo SMTP. If these are filled, Brevo wins over local SMTP in auto mode.
BREVO_EMAIL_HOST=smtp-relay.brevo.com
BREVO_EMAIL_PORT=587
BREVO_EMAIL_USE_TLS=True
BREVO_EMAIL_USE_SSL=False
BREVO_EMAIL_HOST_USER=your-brevo-smtp-login
BREVO_EMAIL_HOST_PASSWORD=your-brevo-smtp-key
BREVO_DEFAULT_FROM_EMAIL=DACHApply <your-verified-sender@example.com>

# Optional local SMTP fallback, e.g. Gmail App Password.
# Paste Gmail app passwords without spaces.
LOCAL_EMAIL_HOST=smtp.gmail.com
LOCAL_EMAIL_PORT=587
LOCAL_EMAIL_USE_TLS=True
LOCAL_EMAIL_USE_SSL=False
LOCAL_EMAIL_HOST_USER=your-gmail-address@gmail.com
LOCAL_EMAIL_HOST_PASSWORD=your-gmail-app-password-without-spaces
LOCAL_DEFAULT_FROM_EMAIL=DACHApply <your-gmail-address@gmail.com>

# Abuse protection rate limits. Django REST Framework format: <number>/<second|minute|hour|day>.
RATE_LIMIT_LOGIN_IP=10/minute
RATE_LIMIT_LOGIN_ACCOUNT=5/minute
RATE_LIMIT_REGISTER_IP=5/hour
RATE_LIMIT_PASSWORD_RESET_IP=5/hour
RATE_LIMIT_PASSWORD_RESET_EMAIL=5/hour
RATE_LIMIT_PUBLIC_SUBMIT_IP=20/hour
RATE_LIMIT_IMPORT_USER=60/hour
