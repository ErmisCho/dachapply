# Azure production/staging environment
# Do not commit real values. Copy these keys into Azure App Settings / Container environment variables.

DEBUG=False
DACHAPPLY_ENV=azure
SECRET_KEY=change-me-to-a-strong-random-secret
ALLOWED_HOSTS=your-app.azurecontainerapps.io,your-custom-domain.example.com
FRONTEND_URL=https://your-app.azurecontainerapps.io
CSRF_TRUSTED_ORIGINS=https://your-app.azurecontainerapps.io,https://your-custom-domain.example.com
CORS_ALLOWED_ORIGINS=https://your-app.azurecontainerapps.io,https://your-custom-domain.example.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=True

SECURE_SSL_REDIRECT=True
USE_X_FORWARDED_PROTO=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# Enable HSTS only after HTTPS is verified.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Brevo SMTP for production password reset emails.
# Authorize Azure outbound IP(s) in Brevo first.
EMAIL_PROVIDER=brevo
EMAIL_TIMEOUT=10
BREVO_EMAIL_HOST=smtp-relay.brevo.com
BREVO_EMAIL_PORT=587
BREVO_EMAIL_USE_TLS=True
BREVO_EMAIL_USE_SSL=False
BREVO_EMAIL_HOST_USER=your-brevo-smtp-login
BREVO_EMAIL_HOST_PASSWORD=your-brevo-smtp-key
BREVO_DEFAULT_FROM_EMAIL=DACHApply <your-verified-sender@example.com>

RATE_LIMIT_LOGIN_IP=10/minute
RATE_LIMIT_LOGIN_ACCOUNT=5/minute
RATE_LIMIT_REGISTER_IP=5/hour
RATE_LIMIT_PASSWORD_RESET_IP=5/hour
RATE_LIMIT_PASSWORD_RESET_EMAIL=5/hour
RATE_LIMIT_PUBLIC_SUBMIT_IP=20/hour
RATE_LIMIT_IMPORT_USER=60/hour
