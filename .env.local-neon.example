# Local development with Neon/Postgres database and local console email
# Copy values into .env if you want local Django to use Neon while avoiding Brevo local IP restrictions.

DEBUG=True
DACHAPPLY_ENV=local-neon
FRONTEND_URL=http://localhost:5173
DACHAPPLY_DEMO_SEED_SCHEDULER=0

# Paste your Neon connection string here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_SSL_REQUIRE=True

# Local email: password reset emails print in the backend terminal.
EMAIL_PROVIDER=console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=DACHApply <local@dachapply.test>
EMAIL_TIMEOUT=10
