# Local development environment
# Copy to .env for local development if you do not want local email to call Brevo.

DEBUG=True
DACHAPPLY_ENV=local
FRONTEND_URL=http://localhost:5173

# Owner-only local Codex CV generation.
CODEX_CV_ENABLED=True
CODEX_CV_OWNER_EMAIL=ermis.chorinopoulos@gmail.com
CODEX_CV_WORKSPACE=C:\latex
CODEX_CANDIDATE_EVIDENCE_PATH=C:\Users\Administrator\Backup\Projects\dachapply\Ermis-Chorinopoulos-Candidate-Evidence.md
CODEX_APPLICATION_RULES_PATH=C:\Users\Administrator\Backup\Projects\dachapply\job-application-adaptation-rules.md
CODEX_CV_OPEN_OUTPUT_FOLDER=True

# Local DB option. Leave DATABASE_URL empty to use backend/db.sqlite3.
# If you want to test against Neon locally, set DATABASE_URL instead.
DATABASE_URL=
DB_SSL_REQUIRE=False

# Local email: password reset emails print in the Django backend terminal.
# This avoids Brevo/Gmail SMTP authentication issues during local development.
EMAIL_PROVIDER=console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=DACHApply <local@dachapply.test>
EMAIL_TIMEOUT=10

# Optional: only needed if you deliberately want to test real SMTP locally.
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=your-brevo-smtp-login
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key
